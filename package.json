{
  "name": "cv-sveltekit",
  "version": "0.1.1",
  "type": "module",
  "volta": {
    "node": "24.12.0",
    "pnpm": "10.6.5"
  },
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "preinstall": "node ./scripts/preinstall.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:eslint": "eslint ./**/*.{js,jsx,ts,tsx,svelte} --cache --fix",
    "lint:style": "stylelint ./**/*.{css,scss,svelte} --cache --fix",
    "format": "prettier --write .",
    "lint:lint-staged": "lint-staged",
    "test:unit": "vitest",
    "cz": "czg",
    "log": "conventional-changelog -p cmyr-config -i CHANGELOG.md -s -r 0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.54.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/eslint": "^9.6.1",
    "@unocss/eslint-config": "^66.6.6",
    "@unocss/extractor-svelte": "^66.6.6",
    "@unocss/reset": "^66.6.6",
    "autoprefixer": "^10.4.27",
    "conventional-changelog-cli": "^5.0.0",
    "cssnano": "^7.1.3",
    "czg": "^1.12.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "postcss": "^8.5.8",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "sass": "^1.98.0",
    "stylelint": "^17.4.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^7.6.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-prettier": "^5.0.3",
    "svelte": "^5.53.10",
    "svelte-turnstile": "0.11.0",
    "svelte-check": "^4.4.5",
    "svelte-i18n": "^4.0.1",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "unocss": "^66.6.6",
    "vite": "^7.3.1"
  }
}
