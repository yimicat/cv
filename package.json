{
  "name": "cv-sveltekit",
  "version": "0.1.0",
  "type": "module",
  "volta": {
    "node": "22.13.1",
    "pnpm": "10.6.5"
  },
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "husky",
    "preinstall": "node ./scripts/preinstall.js",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint:eslint": "eslint ./**/*.{js,jsx,ts,tsx,svelte} --cache --fix",
    "lint:style": "stylelint ./**/*.{css,scss,svelte} --cache --fix",
    "format": "prettier --write .",
    "lint:lint-staged": "lint-staged",
    "test:unit": "vitest",
    "cz": "czg",
    "log": "conventional-changelog -p cmyr-config -i CHANGELOG.md -s -r 0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@eslint/js": "^9.23.0",
    "@sveltejs/adapter-node": "^5.2.12",
    "@sveltejs/kit": "^2.37.1",
    "@sveltejs/vite-plugin-svelte": "^3.1.2",
    "@types/eslint": "^8.56.12",
    "@unocss/eslint-config": "^0.62.4",
    "@unocss/extractor-svelte": "^0.62.4",
    "@unocss/reset": "66.1.0-beta.6",
    "autoprefixer": "^10.4.21",
    "conventional-changelog-cli": "^5.0.0",
    "cssnano": "^7.0.6",
    "czg": "^1.11.1",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "postcss": "^8.5.3",
    "postcss-html": "^1.8.0",
    "postcss-scss": "^4.0.9",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "sass": "^1.86.0",
    "stylelint": "^16.17.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-recess-order": "^5.1.1",
    "stylelint-config-standard-scss": "^13.1.0",
    "stylelint-prettier": "^5.0.3",
    "svelte": "^4.2.19",
    "svelte-check": "^3.8.6",
    "svelte-i18n": "^4.0.1",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "unocss": "^0.62.4",
    "vite": "^5.4.19"
  }
}
